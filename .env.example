PORT=3000
JWT_SECRET=change-this-to-a-random-secret
OLLAMA_URL=http://192.168.0.106:11434
OLLAMA_MODEL=gemma4
DB_PATH=./data/deadchat.db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Media generation
COMFYUI_URL=http://192.168.0.106:8188
